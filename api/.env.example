# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financebot

# JWT — use a long random string in production
JWT_SECRET=change_me_to_long_random_string_in_production

# CORS — set to your frontend URL in production
FRONTEND_URL=http://localhost:5173

# Admin fallback (used if no DB users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Shared secret between bot and API — must match bot's BOT_INTERNAL_SECRET
BOT_INTERNAL_SECRET=financebot_internal

# Bot's HTTP server URL — used to evict cached tokens on unlink
BOT_URL=http://localhost:3002

# Port
PORT=3001
