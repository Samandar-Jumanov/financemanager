# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# API connection
API_URL=http://localhost:3001/api

# Shared secret between bot and API — must match API's BOT_INTERNAL_SECRET
BOT_INTERNAL_SECRET=financebot_internal

# Frontend URL (shown in /start message for unlinked users)
FRONTEND_URL=http://localhost:5173

# AI — Groq API key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Production webhook URL (leave empty for local long-polling)
BOT_WEBHOOK_URL=

# Port for webhook server (production only)
PORT=3002
